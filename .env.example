# Copia a .env.local o configura en Vercel → Settings → Environment Variables.
# Cliente (prefijo VITE_): visibles en el bundle; no pongas secretos aquí.

# --- Sitio público (opcional) ---
# Si el canónico es www o un preview: https://www.gafcore.com | https://tu-preview.vercel.app
# VITE_PUBLIC_SITE_URL=https://gafcore.com

# --- Supabase (cliente) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=  (si tu flujo lo usa)

# --- Pagos (cliente) ---
# VITE_PAYMENTS_CLIENT_TOKEN=

# --- Supabase (servidor / SSR) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (servidor): una de las opciones — usadas por POST /api/gafcore/chat/stream (chat del IDE) ---
# Opción A — URL completa + clave (OpenAI, Azure OpenAI, proxy propio, etc.)
# AI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# AI_API_KEY=
#
# Opción B — OpenRouter (recomendado si quieres varios modelos con un solo proveedor)
OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=https://gafcore.com
# OPENROUTER_APP_TITLE=GafCore
#
# Opción C — OpenAI directo (api.openai.com)
OPENAI_API_KEY=
# Opcional: override de modelos. Si omites ambas, el servidor usa gpt-4o-mini / gpt-4o en api.openai.com
# y los slugs OpenRouter si usas OPENROUTER_API_KEY.
# AI_MODEL_FAST=gpt-4o-mini
# AI_MODEL_DEEP=gpt-4o

# Modelos opcionales (override explícito en cualquier proveedor)
# AI_MODEL_FAST=
# AI_MODEL_DEEP=
# AI_SUPPORT_MODEL=

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
# ELEVENLABS_API_KEY_1=

# --- Stripe (secret keys de tu cuenta Stripe) ---
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=

# --- Paddle (API keys oficiales sandbox / live) ---
PADDLE_SANDBOX_API_KEY=
PADDLE_LIVE_API_KEY=

# --- YouTube OAuth ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Otros (solo si usas la feature) ---
# REPLICATE_API_TOKEN=
# GAFCORE_ADMIN_CODE=
# MASTER_SIGNUP_CODE=
# Límite de registros email/contraseña por IP y día UTC (tras migración signup_ip_rate_limits).
# GAFCORE_SIGNUP_MAX_PER_IP_PER_DAY=8
# Sal opcional para hashear IPs en BD (recomendado en producción).
# GAFCORE_SIGNUP_IP_SALT=

# --- Cloudflare Turnstile (registro): site key en cliente, secret solo en servidor ---
# VITE_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
