# =============================================================================
# GafCore — variables de entorno (plantilla)
# Copia a `.env.local` para desarrollo. En producción: Vercel → Environment Variables.
# NUNCA subas `.env`, `.env.local` ni secretos al repositorio.
# Verificación: npm run gafcore:doctor
# =============================================================================

# --- Cliente (Vite) — solo variables VITE_* (públicas en el bundle) ---
# NUNCA uses VITE_ para OPENAI_API_KEY, SERVICE_ROLE, STRIPE_SECRET, etc.
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=tu-project-id
VITE_PUBLIC_SITE_URL=https://gafcore.com

# --- Servidor — Supabase (mismos valores que VITE_ donde aplique) ---
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Cerebro Central — IA (al menos UNA vía) ---
# Recomendado: una sola key OpenRouter para GPT + Gemini + Claude
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_HTTP_REFERER=https://gafcore.com
OPENROUTER_APP_TITLE=GafCore

# Alternativa: OpenAI directo
OPENAI_API_KEY=sk-...

# Alternativa: Anthropic directo (OpenRouter preferido para streaming IDE)
ANTHROPIC_API_KEY=sk-ant-...

# Alternativa: Google AI Studio / Gemini directo
GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=

# Endpoint OpenAI-compatible custom
AI_CHAT_COMPLETIONS_URL=
AI_API_KEY=

# Modelos por tarea (slugs OpenRouter o IDs nativos)
AI_MODEL_FAST=google/gemini-2.0-flash-001
# Diagnóstico sistémico SRE (opcional; por defecto AI_MODEL_FAST o gemini-2.5-flash)
# AI_MODEL_SYSTEMIC=google/gemini-2.5-flash
# Modo profundo chat: AI_MODEL_DEEP (Claude/GPT-4o) + AI_MODEL_UI (Gemini Pro) + AI_MODEL_FAST (Flash)
# Prompts completos en dev (más tokens): GAFCORE_FULL_PROMPTS=1
# Cerebro único V2 (por defecto ON). Legacy sandwich: GAFCORE_BRAIN_LEGACY=1
# Logs debug servidor: GAFCORE_DEBUG=1
AI_MODEL_DEEP=openai/gpt-4o
AI_MODEL_UI=google/gemini-2.5-pro
AI_SUPPORT_MODEL=

# --- Voz (módulo ElevenLabs, no chat completions) ---
ELEVENLABS_API_KEY=

# --- Pagos — Stripe ---
VITE_PAYMENTS_CLIENT_TOKEN=pk_test_...
STRIPE_SANDBOX_API_KEY=sk_test_...
PAYMENTS_SANDBOX_WEBHOOK_SECRET=whsec_...
STRIPE_LIVE_API_KEY=sk_live_...
PAYMENTS_LIVE_WEBHOOK_SECRET=whsec_...

# --- Paddle (opcional) ---
PADDLE_API_KEY=

# --- Deploy / GitHub publish (opcional) ---
# GITHUB_TOKEN=
# GAFCORE_GITHUB_ORG=

# --- Turnstile / captcha (opcional) ---
# VITE_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
