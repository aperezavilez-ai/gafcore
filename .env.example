# Copia a .env.local o configura en Vercel → Settings → Environment Variables.
# Cliente (prefijo VITE_): visibles en el bundle; no pongas secretos aquí.

# --- Sitio público (recomendado en Vercel / producción) ---
# Sin esto, si alguien pide «recuperar contraseña» desde localhost, el correo puede llevar localhost en el enlace.
# VITE_PUBLIC_SITE_URL=https://gafcore.com   (recomendado en Vercel Production)
#
# Origen explícito para enlaces de Auth en correo (recovery, confirmación). Debe estar en Supabase → Auth → Redirect URLs.
# VITE_AUTH_EMAIL_REDIRECT_ORIGIN=http://127.0.0.1:8081

# --- Supabase (cliente) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=  (si tu flujo lo usa)

# --- Pagos (cliente) ---
# Clave publicable Stripe (pk_test_… / pk_live_…): mismo modo (test/live) que STRIPE_SANDBOX_API_KEY / STRIPE_LIVE_API_KEY en el servidor.
# Paquetes de créditos en el IDE: en Stripe cada precio de pago único debe tener lookup_key = credits_pack_50, credits_pack_100, … (o usar el id price_… en código).
# VITE_PAYMENTS_CLIENT_TOKEN=

# --- Supabase (servidor / SSR) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (servidor): una de las opciones — usadas por POST /api/gafcore/chat/stream (chat del IDE) ---
# Opción A — URL completa + clave (OpenAI, Azure OpenAI, proxy propio, etc.)
# AI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# AI_API_KEY=
#
# Opción B — OpenRouter (recomendado si quieres varios modelos con un solo proveedor)
OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=https://gafcore.com
# OPENROUTER_APP_TITLE=GafCore
#
# Opción C — OpenAI directo (api.openai.com)
OPENAI_API_KEY=
# Opcional: override de modelos. Si omites ambas, el servidor usa gpt-4o-mini / gpt-4o en api.openai.com
# y los slugs OpenRouter si usas OPENROUTER_API_KEY.
# AI_MODEL_FAST=gpt-4o-mini
# AI_MODEL_DEEP=gpt-4o

# Modelos opcionales (override explícito en cualquier proveedor)
# AI_MODEL_FAST=
# AI_MODEL_DEEP=
# AI_SUPPORT_MODEL=

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
# ELEVENLABS_API_KEY_1=

# --- Stripe (secret keys de tu cuenta Stripe) ---
# Tras poner STRIPE_SANDBOX_API_KEY en .env.local: npm run gafcore:stripe-bootstrap
# Crea lookup_key plan_basico_monthly, plan_pro_monthly, plan_premium_monthly, plan_creador_monthly, credits_pack_* (precios provisionales).
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=

# --- Paddle (API keys oficiales sandbox / live) ---
PADDLE_SANDBOX_API_KEY=
PADDLE_LIVE_API_KEY=

# --- YouTube OAuth ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Generación de imágenes (IDE: si una URL falla y el prompt pide fotos premium) ---
# REPLICATE_API_TOKEN=   # https://replicate.com/account/api-tokens — modelo Flux Schnell

# --- Publicar (servidor — Etapa 2) ---
# GAFCORE_DEPLOY_GITHUB_TOKEN=   # Opcional: PAT de plataforma para todos los deploys
# GAFCORE_DEPLOY_VALIDATION_GATE=hard   # hard | soft | off — validar calidad antes de publicar
# Migración SQL: 20260520120000_user_github_credentials.sql (token por usuario cifrado)
# VERCEL_TOKEN=   # Etapa 3: crea/enlaza proyecto Vercel y deploy tras push a GitHub
# VERCEL_TEAM_ID= # Opcional: id de equipo si el token es de team (no cuenta personal)
# VERCEL_WEBHOOK_SECRET= # Webhook Vercel → POST /api/gafcore/vercel-webhook (deployment events)

# --- Otros (solo si usas la feature) ---
# GAFCORE_ADMIN_CODE=
# MASTER_SIGNUP_CODE=
# Límite de registros email/contraseña por IP y día UTC (tras migración signup_ip_rate_limits).
# GAFCORE_SIGNUP_MAX_PER_IP_PER_DAY=8
# Sal opcional para hashear IPs en BD (recomendado en producción).
# GAFCORE_SIGNUP_IP_SALT=

# --- Cloudflare Turnstile (registro): site key en cliente, secret solo en servidor ---
# VITE_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- Workflow multiagente (B0–B4) ---
# GAFCORE_WORKFLOW_MAX_PARALLEL=3
# GAFCORE_WORKFLOW_MAX_ACTIVE_PER_USER=2   # workflows en planning/executing por usuario
# CRON_SECRET=   # Vercel Cron → Authorization: Bearer (Pro). También x-cron-secret manual.
