{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": null,
  "headers": [
    {
      "source": "/gafcore",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/gafcore/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
