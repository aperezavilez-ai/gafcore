{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "destination": "/gafcore",
      "permanent": false
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/gafcore",
      "statusCode": 410
    },
    {
      "source": "/sw.js",
      "destination": "/gafcore",
      "statusCode": 410
    }
  ],
  "crons": [
    {
      "path": "/api/gafcore/workflow/drain",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/gafcore",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/gafcore/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/favicon.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/favicon.svg",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
